    border-radius: 8px;
    margin-top: 10px;
    font-weight: bold;
    font-size: 13px;
    color: #55aaff;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 5px;
}
QPushButton {
    background-color: #212121;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    padding: 6px 12px;
    font-weight: bold;
    color: #ffffff;
}
QPushButton:hover {
    background-color: #333333;
    border: 1px solid #55aaff;
}
QPushButton:pressed {
    background-color: #55aaff;
    color: #121212;
}
QSlider::groove:horizontal {
    border: 1px solid #3a3a3a;
    height: 6px;
    background: #212121;
    border-radius: 3px;
}
QSlider::sub-page:horizontal {
    background: #55aaff;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #ffffff;
    border: 1px solid #55aaff;
    width: 14px;
    margin-top: -4px;
    margin-bottom: -4px;
    border-radius: 7px;
}
QLabel {
    font-weight: 500;
}</string>
