  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #0d0e12;
}
QWidget {
    color: #e2e8f0;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
    font-size: 11px;
}
QGroupBox {
    border: 1px solid #1e293b;
    border-radius: 8px;
    margin-top: 15px;
    font-weight: bold;
    font-size: 12px;
    color: #38bdf8;
    background-color: #111827;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 15px;
    padding: 0 8px;
}
QPushButton {
    background-color: #1f2937;
    border: 1px solid #374151;
    border-radius: 6px;
    padding: 6px 12px;
    font-weight: bold;
    color: #f3f4f6;
}
QPushButton:hover {
    background-color: #374151;
    border: 1px solid #38bdf8;
}
QPushButton:pressed {
    background-color: #0284c7;
    color: #ffffff;
}
QSlider::groove:horizontal {
    border: 1px solid #374151;
    height: 8px;
    background: #1f2937;
    border-radius: 4px;
}
QSlider::sub-page:horizontal {
    background: #38bdf8;
    border-radius: 4px;
}
QSlider::handle:horizontal {
    background: #ffffff;
    border: 1px solid #38bdf8;
    width: 16px;
    height: 16px;
    margin-top: -4px;
    margin-bottom: -4px;
    border-radius: 8px;
}
QComboBox {
    background-color: #1f2937;
    border: 1px solid #374151;
    border-radius: 6px;
    padding: 5px;
    color: #f3f4f6;
    min-width: 100px;
}
QComboBox:hover {
    border: 1px solid #38bdf8;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left-width: 1px;
    border-left-color: #374151;
    border-left-style: solid;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}
QSpinBox {
    background-color: #1f2937;
    border: 1px solid #374151;
    border-radius: 6px;
    padding: 5px;
    color: #f3f4f6;
}
QLabel {
    font-weight: 500;
}</string>
